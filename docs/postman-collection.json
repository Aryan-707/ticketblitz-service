{
  "info": {
    "name": "TicketBlitz",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — success",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\"firstName\": \"Jane\",\"lastName\": \"Doe\",\"email\": \"jane@example.com\",\"password\": \"secret\",\"role\": \"CUSTOMER\"}" }
          }
        },
        {
          "name": "Login — success",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\"email\": \"jane@example.com\",\"password\": \"secret\"}" }
          }
        },
        {
          "name": "Login — failure (403)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\"email\": \"jane@example.com\",\"password\": \"wrongpass\"}" }
          }
        }
      ]
    },
    {
      "name": "Purchase",
      "item": [
        {
          "name": "Purchase Seat — success",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/stock/purchase", "host": ["{{base_url}}"], "path": ["api", "stock", "purchase"] },
            "body": { "mode": "raw", "raw": "{\"eventId\": 1,\"tierId\": 1,\"seatId\": 134,\"idempotencyKey\": \"{{$guid}}\"}" }
          }
        },
        {
          "name": "Purchase Seat — duplicate idempotency key (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/stock/purchase", "host": ["{{base_url}}"], "path": ["api", "stock", "purchase"] },
            "body": { "mode": "raw", "raw": "{\"eventId\": 1,\"tierId\": 1,\"seatId\": 134,\"idempotencyKey\": \"same-uuid-used-twice\"}" }
          }
        },
        {
          "name": "Purchase Seat — missing auth token (401)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{base_url}}/api/stock/purchase", "host": ["{{base_url}}"], "path": ["api", "stock", "purchase"] },
            "body": { "mode": "raw", "raw": "{\"eventId\": 1,\"tierId\": 1,\"seatId\": 134,\"idempotencyKey\": \"{{$guid}}\"}" }
          }
        }
      ]
    }
  ]
}
